<Window x:Class="DietCanteen.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="Диетическая столовая" Height="700" Width="950"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="#E8F5E9">

    <Window.Resources>
        <FontFamily x:Key="DolomanFont">/Fonts/DolomanPavljenko.otf#Doloman Pavljenko</FontFamily>

        <!-- Стиль для вкладок с зелёным фоном -->
        <Style TargetType="TabItem">
            <Setter Property="Background" Value="#C8E6C9"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <!-- Стиль для кнопок -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="#A5D6A7"/>
            <Setter Property="BorderBrush" Value="#4CAF50"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="5,3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#81C784"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для DataGrid -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="AlternatingRowBackground" Value="#F1F8E9"/>
            <Setter Property="RowBackground" Value="#FFFFFF"/>
        </Style>
    </Window.Resources>

    <Grid Margin="5" Background="#E8F5E9">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" 
                   Text="Диетическая столовая - Расчет калорийности и состава блюд" 
                   FontFamily="{StaticResource DolomanFont}"
                   FontSize="20" 
                   FontWeight="Bold" 
                   HorizontalAlignment="Center" 
                   Margin="0,0,0,5"
                   TextWrapping="Wrap"
                   Foreground="#1B5E20"/>

        <TabControl Grid.Row="1" Margin="0,5" Background="#E8F5E9">

            <!-- Вкладка 1: Список блюд -->
            <TabItem Header="📋 Список блюд" Background="#C8E6C9">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Background="#E8F5E9">
                    <Grid Margin="5" Background="#E8F5E9">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="250"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="180"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <WrapPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,5">
                            <Button Name="btnLoad" Content="📂 Загрузить" Width="100" Height="28" Margin="2" Click="btnLoad_Click"/>
                            <Button Name="btnShowDishes" Content="🍽️ Все блюда" Width="110" Height="28" Margin="2" Click="btnShowDishes_Click" IsEnabled="False"/>
                            <Button Name="btnShowMenu" Content="✅ Меню" Width="80" Height="28" Margin="2" Click="btnShowMenu_Click" IsEnabled="False"/>
                            <Button Name="btnReset" Content="🔄 Сброс" Width="80" Height="28" Margin="2" Click="btnReset_Click" IsEnabled="False"/>
                        </WrapPanel>

                        <TextBlock Grid.Row="1" Text="Список блюд с расчетом КБЖУ:" FontSize="13" FontWeight="Bold" Margin="0,0,0,3" Foreground="#2E7D32"/>
                        <DataGrid Grid.Row="2" Name="dgDishes" AutoGenerateColumns="True" 
                                  IsReadOnly="True" 
                                  SelectionChanged="dgDishes_SelectionChanged"
                                  VerticalScrollBarVisibility="Visible"
                                  HorizontalScrollBarVisibility="Auto"
                                  FontSize="12"
                                  RowHeight="25">
                        </DataGrid>

                        <Separator Grid.Row="3" Margin="0,5" Height="1" Background="#A5D6A7"/>

                        <StackPanel Grid.Row="4" Margin="0,3">
                            <TextBlock Text="Состав выбранного блюда:" FontSize="13" FontWeight="Bold" Margin="0,0,0,3" Foreground="#2E7D32"/>
                            <TextBlock Name="txtSelectedDish" Text="Выберите блюдо из списка" FontSize="13" 
                                       Foreground="#1B5E20" Margin="0,0,0,3"/>
                            <DataGrid Name="dgIngredients" AutoGenerateColumns="True" IsReadOnly="True"
                                      VerticalScrollBarVisibility="Visible"
                                      HorizontalScrollBarVisibility="Auto"
                                      FontSize="12"
                                      RowHeight="25"
                                      MaxHeight="120">
                            </DataGrid>
                        </StackPanel>

                        <Border Grid.Row="5" Background="#DCEDC8" BorderBrush="#81C784" BorderThickness="1" 
                                Margin="0,5" Padding="5" CornerRadius="5">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Margin="3">
                                    <TextBlock Text="📊 Информация о выбранном блюде:" FontWeight="Bold" FontSize="13" Margin="0,0,0,5" Foreground="#2E7D32"/>
                                    <TextBlock Name="txtCalories" Text="🔥 Калорийность: -" FontSize="12" Margin="0,2"/>
                                    <TextBlock Name="txtProtein" Text="🍗 Белки: -" FontSize="12" Margin="0,2"/>
                                    <TextBlock Name="txtFat" Text="🧈 Жиры: -" FontSize="12" Margin="0,2"/>
                                    <TextBlock Name="txtCarbs" Text="🍚 Углеводы: -" FontSize="12" Margin="0,2"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Margin="3">
                                    <TextBlock Text="📈 Статистика по всем блюдам:" FontWeight="Bold" FontSize="13" Margin="0,0,0,5" Foreground="#2E7D32"/>
                                    <TextBlock Name="txtTotalDishes" Text="🍽️ Всего блюд: -" FontSize="12" Margin="0,2"/>
                                    <TextBlock Name="txtMenuDishes" Text="✅ В меню: -" FontSize="12" Margin="0,2"/>
                                    <TextBlock Name="txtAvgCalories" Text="📊 Средняя калорийность: -" FontSize="12" Margin="0,2"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <!-- Вкладка 2: Добавление -->
            <TabItem Header="➕ Добавление" Background="#C8E6C9">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Background="#E8F5E9">
                    <Grid Margin="10" MinWidth="500" Background="#E8F5E9">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Добавление продукта -->
                        <Border Grid.Row="0" Background="#DCEDC8" BorderBrush="#66BB6A" BorderThickness="1" 
                                CornerRadius="8" Padding="10" Margin="0,0,0,15">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Text="🌱 Добавление нового продукта (ингредиента)" 
                                           FontSize="13" FontWeight="Bold" Margin="0,0,0,10" Foreground="#2E7D32"/>

                                <Grid Grid.Row="1" Margin="0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" Text="Название:" VerticalAlignment="Center" FontWeight="Bold" FontSize="13"/>
                                    <TextBox Grid.Column="1" Name="txtProductName" Margin="5" Height="30" FontSize="13"/>

                                    <TextBlock Grid.Column="2" Text="Калории (ккал):" VerticalAlignment="Center" FontWeight="Bold" FontSize="13"/>
                                    <TextBox Grid.Column="3" Name="txtProductCalories" Margin="5" Height="30" FontSize="13"/>
                                </Grid>

                                <Grid Grid.Row="2" Margin="0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" Text="Белки (г):" VerticalAlignment="Center" FontWeight="Bold" FontSize="13"/>
                                    <TextBox Grid.Column="1" Name="txtProductProtein" Margin="5" Height="30" FontSize="13"/>

                                    <TextBlock Grid.Column="2" Text="Жиры (г):" VerticalAlignment="Center" FontWeight="Bold" FontSize="13"/>
                                    <TextBox Grid.Column="3" Name="txtProductFat" Margin="5" Height="30" FontSize="13"/>
                                </Grid>

                                <Grid Grid.Row="3" Margin="0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" Text="Углеводы (г):" VerticalAlignment="Center" FontWeight="Bold" FontSize="13"/>
                                    <TextBox Grid.Column="1" Name="txtProductCarbs" Margin="5" Height="30" FontSize="13"/>
                                    <Button Grid.Column="2" Name="btnAddProduct" Content="➕ Добавить" 
                                            Width="100" Height="35" Margin="5,5,0,5" Click="btnAddProduct_Click" 
                                            Background="#66BB6A" Foreground="White" FontWeight="Bold" FontSize="13"/>
                                </Grid>
                            </Grid>
                        </Border>

                        <!-- Добавление блюда -->
                        <Border Grid.Row="1" Background="#FFF8E1" BorderBrush="#FFB74D" BorderThickness="1" 
                                CornerRadius="8" Padding="10" Margin="0,0,0,15">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Text="🍲 Добавление нового блюда" 
                                           FontSize="13" FontWeight="Bold" Margin="0,0,0,10" Foreground="#E65100"/>

                                <Grid Grid.Row="1" Margin="0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" Text="Название блюда:" VerticalAlignment="Center" FontWeight="Bold" FontSize="13"/>
                                    <TextBox Grid.Column="1" Name="txtNewDishName" Margin="5" Height="30" FontSize="13"/>

                                    <TextBlock Grid.Column="2" Text="Цена (BYN):" VerticalAlignment="Center" FontWeight="Bold" FontSize="13"/>
                                    <TextBox Grid.Column="3" Name="txtNewPrice" Margin="5" Height="30" FontSize="13"/>
                                </Grid>

                                <CheckBox Grid.Row="2" Name="chkNewInMenu" Content="✅ Включено в меню" Margin="0,10" FontWeight="Bold" FontSize="13"/>

                                <TextBlock Grid.Row="3" Text="🥕 Ингредиенты блюда:" FontWeight="Bold" FontSize="13" Margin="0,10,0,5"/>

                                <Grid Grid.Row="4" Margin="0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <ComboBox Grid.Column="0" Name="cmbProductName" Margin="3" FontSize="13"
                                              DisplayMemberPath="Name" SelectedValuePath="Name"/>
                                    <TextBox Grid.Column="1" Name="txtQuantity" Margin="3" Text="100" FontSize="13" ToolTip="Количество в граммах"/>
                                    <ComboBox Grid.Column="2" Name="cmbProcessing" Margin="3" FontSize="13">
                                        <ComboBoxItem>Варка</ComboBoxItem>
                                        <ComboBoxItem>Жарка</ComboBoxItem>
                                        <ComboBoxItem>Тушение</ComboBoxItem>
                                        <ComboBoxItem>Запекание</ComboBoxItem>
                                        <ComboBoxItem>Нарезка</ComboBoxItem>
                                        <ComboBoxItem>Смешивание</ComboBoxItem>
                                        <ComboBoxItem>Пассерование</ComboBoxItem>
                                    </ComboBox>
                                    <Button Grid.Column="3" Name="btnAddIngredient" Content="➕ Добавить" 
                                            Width="100" Height="30" Margin="3" Click="btnAddIngredient_Click"
                                            Background="#FFB74D" Foreground="White" FontWeight="Bold" FontSize="12"/>
                                </Grid>

                                <DataGrid Grid.Row="5" Name="dgNewIngredients" AutoGenerateColumns="False" 
                                          CanUserDeleteRows="True" Margin="0,5" Height="150" FontSize="12"
                                          Background="#FFFFFF" AlternatingRowBackground="#F1F8E9">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Продукт" Width="150" Binding="{Binding ProductName}"/>
                                        <DataGridTextColumn Header="Количество (г)" Width="100" Binding="{Binding Quantity}"/>
                                        <DataGridTextColumn Header="Обработка" Width="120" Binding="{Binding Processing}"/>
                                        <DataGridTemplateColumn Header="🗑️" Width="50">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button Content="✖" Click="RemoveIngredient_Click" 
                                                            Background="#EF9A9A" Width="30" Height="22" Cursor="Hand"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                                    <Button Name="btnSaveDish" Content="💾 Сохранить" Width="100" Height="35" 
                                            Margin="5" Click="btnSaveDish_Click" Background="#66BB6A" 
                                            Foreground="White" FontWeight="Bold" FontSize="13"/>
                                    <Button Name="btnClearDishForm" Content="🧹 Очистить" Width="100" Height="35" 
                                            Margin="5" Click="btnClearDishForm_Click" Background="#FFB74D" FontSize="13"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <!-- Вкладка 3: Удаление -->
            <TabItem Header="🗑️ Удаление" Background="#C8E6C9">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Background="#E8F5E9">
                    <Grid Margin="10" MinWidth="500" Background="#E8F5E9">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Удаление продукта -->
                        <Border Grid.Row="0" Background="#FFEBEE" BorderBrush="#EF9A9A" BorderThickness="1" 
                                CornerRadius="8" Padding="10" Margin="0,0,0,15">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Text="⚠️ Удаление продукта (ингредиента)" 
                                           FontSize="13" FontWeight="Bold" Margin="0,0,0,10" Foreground="#C62828"/>

                                <Grid Grid.Row="1" Margin="0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" Text="Выберите продукт:" VerticalAlignment="Center" FontWeight="Bold" FontSize="13"/>
                                    <ComboBox Grid.Column="1" Name="cmbDeleteProduct" Margin="3" FontSize="13"
                                              DisplayMemberPath="Name" SelectedValuePath="Name"/>
                                    <Button Grid.Column="2" Name="btnDeleteProduct" Content="🗑️ Удалить" 
                                            Width="85" Height="30" Margin="3,3,0,3" Click="btnDeleteProduct_Click" 
                                            Background="#EF9A9A" Foreground="White" FontWeight="Bold" FontSize="12"/>
                                </Grid>

                                <Border Grid.Row="2" Background="#FFF5F5" CornerRadius="5" Padding="5" Margin="0,10">
                                    <TextBlock Text="⚠️ Внимание: При удалении продукта, все блюда, использующие этот продукт, также будут удалены!" 
                                               FontSize="11" Foreground="#C62828" TextWrapping="Wrap"/>
                                </Border>

                                <StackPanel Grid.Row="3" Margin="0,5">
                                    <TextBlock Text="🍽️ Блюда, которые будут удалены:" FontWeight="Bold" FontSize="12" Margin="0,0,0,5" Foreground="#C62828"/>
                                    <ListBox Name="lstAffectedDishes" Height="100" Margin="0,5" 
                                             FontSize="12" Foreground="#C62828" Background="#FFF5F5"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Удаление блюда -->
                        <Border Grid.Row="1" Background="#FFF3E0" BorderBrush="#FFB74D" BorderThickness="1" 
                                CornerRadius="8" Padding="10" Margin="0,0,0,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Text="⚠️ Удаление блюда" 
                                           FontSize="13" FontWeight="Bold" Margin="0,0,0,10" Foreground="#E65100"/>

                                <Grid Grid.Row="1" Margin="0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" Text="Выберите блюдо:" VerticalAlignment="Center" FontWeight="Bold" FontSize="13"/>
                                    <ComboBox Grid.Column="1" Name="cmbDeleteDish" Margin="3" FontSize="13"
                                              DisplayMemberPath="Name" SelectedValuePath="Name"/>
                                    <Button Grid.Column="2" Name="btnDeleteDish" Content="🗑️ Удалить" 
                                            Width="85" Height="30" Margin="3,3,0,3" Click="btnDeleteDishFromTab_Click" 
                                            Background="#FFB74D" Foreground="White" FontWeight="Bold" FontSize="12"/>
                                </Grid>

                                <Border Grid.Row="2" Background="#FFF8E1" CornerRadius="5" Padding="5" Margin="0,10">
                                    <StackPanel>
                                        <TextBlock Text="📋 Информация о блюде:" FontWeight="Bold" FontSize="12" Margin="0,0,0,5" Foreground="#E65100"/>
                                        <TextBlock Name="txtDishInfo" Text="Выберите блюдо для просмотра информации" FontSize="12" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Row="3" Background="#FFF5F5" CornerRadius="5" Padding="5" Margin="0,5">
                                    <TextBlock Text="ℹ️ Удаление блюда не повлияет на список продуктов." 
                                               FontSize="11" Foreground="#E65100" TextWrapping="Wrap"/>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <!-- Вкладка 4: Планирование меню -->
            <TabItem Header="📅 Планирование меню" Background="#C8E6C9">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Background="#E8F5E9">
                    <Grid Margin="10" MinWidth="700" Background="#E8F5E9">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Background="#DCEDC8" BorderBrush="#81C784" BorderThickness="1" 
                                CornerRadius="8" Padding="10" Margin="0,0,0,15">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0" Grid.ColumnSpan="3" Text="📅 Составление меню на день" 
                                           FontSize="13" FontWeight="Bold" Margin="0,0,0,10" Foreground="#2E7D32"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Дата:" VerticalAlignment="Center" 
                                           FontWeight="Bold" FontSize="13" Margin="0,0,10,0"/>
                                <DatePicker Grid.Row="1" Grid.Column="1" Name="dpMenuDate" 
                                            SelectedDate="{x:Static sys:DateTime.Today}"
                                            Margin="0,0,10,0" VerticalAlignment="Center" FontSize="13"/>

                                <StackPanel Grid.Row="1" Grid.Column="2" Orientation="Horizontal">
                                    <Button Name="btnLoadDailyMenu" Content="📂 Загрузить" Width="90" Height="30" 
                                            Margin="2" Click="btnLoadDailyMenu_Click" 
                                            Background="#81C784" Foreground="White" FontWeight="Bold" FontSize="12"/>
                                    <Button Name="btnSaveDailyMenu" Content="💾 Сохранить" Width="90" Height="30" 
                                            Margin="2" Click="btnSaveDailyMenu_Click" 
                                            Background="#66BB6A" Foreground="White" FontWeight="Bold" FontSize="12"/>
                                    <Button Name="btnClearDailyMenu" Content="🧹 Очистить" Width="85" Height="30" 
                                            Margin="2" Click="btnClearDailyMenu_Click" 
                                            Background="#A5D6A7" Foreground="White" FontWeight="Bold" FontSize="12"/>
                                </StackPanel>

                                <TextBox Grid.Row="2" Grid.ColumnSpan="3" Name="txtMenuNotes" 
                                         Margin="0,10,0,0" Height="50" TextWrapping="Wrap"
                                         FontSize="12" ToolTip="Примечания к меню на этот день"/>
                            </Grid>
                        </Border>

                        <!-- Выбор блюд -->
                        <Grid Grid.Row="1" Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Background="#DCEDC8" BorderBrush="#81C784" BorderThickness="1" 
                                    CornerRadius="8" Padding="10">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Text="🍽️ Доступные блюда" FontSize="13" FontWeight="Bold" 
                                               Margin="0,0,0,10" Foreground="#2E7D32"/>

                                    <TextBox Grid.Row="1" Name="txtSearchDish" Margin="0,0,0,10" Height="25"
                                             TextChanged="txtSearchDish_TextChanged"
                                             ToolTip="Поиск блюд..." FontSize="12"/>

                                    <ListBox Grid.Row="2" Name="lstAvailableDishes" 
                                             SelectionMode="Multiple"
                                             DisplayMemberPath="Name"
                                             FontSize="13" Margin="0,5"
                                             Background="#FFFFFF"/>
                                </Grid>
                            </Border>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0">
                                <Button Name="btnAddToMenu" Content="→" Width="45" Height="35" Margin="0,5" 
                                        Click="btnAddToMenu_Click" FontSize="16" FontWeight="Bold"
                                        Background="#66BB6A" Foreground="White"/>
                                <Button Name="btnRemoveFromMenu" Content="←" Width="45" Height="35" Margin="0,5" 
                                        Click="btnRemoveFromMenu_Click" FontSize="16" FontWeight="Bold"
                                        Background="#EF9A9A" Foreground="White"/>
                                <Button Name="btnAddAllToMenu" Content="→→" Width="45" Height="35" Margin="0,5" 
                                        Click="btnAddAllToMenu_Click" FontSize="14" FontWeight="Bold"
                                        Background="#4CAF50" Foreground="White"/>
                                <Button Name="btnRemoveAllFromMenu" Content="←←" Width="45" Height="35" Margin="0,5" 
                                        Click="btnRemoveAllFromMenu_Click" FontSize="14" FontWeight="Bold"
                                        Background="#E57373" Foreground="White"/>
                            </StackPanel>

                            <Border Grid.Column="2" Background="#FFF8E1" BorderBrush="#FFB74D" BorderThickness="1" 
                                    CornerRadius="8" Padding="10">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Text="📋 Меню на выбранную дату" FontSize="13" FontWeight="Bold" 
                                               Margin="0,0,0,10" Foreground="#E65100"/>

                                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                                        <TextBlock Text="🍽️ Итого блюд:" FontSize="12" Margin="0,0,5,0"/>
                                        <TextBlock Name="txtSelectedCount" Text="0" FontSize="12" FontWeight="Bold" 
                                                   Foreground="#E65100"/>
                                        <TextBlock Text="   🔥 Общая калорийность:" FontSize="12" Margin="15,0,5,0"/>
                                        <TextBlock Name="txtTotalCalories" Text="0" FontSize="12" FontWeight="Bold" 
                                                   Foreground="#E65100"/>
                                    </StackPanel>

                                    <ListBox Grid.Row="2" Name="lstSelectedDishes" 
                                             SelectionMode="Multiple"
                                             DisplayMemberPath="Name"
                                             FontSize="13" Margin="0,5"
                                             Background="#FFFFFF"/>
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- Сохраненные меню -->
                        <Border Grid.Row="2" Background="#E0E0E0" BorderBrush="#BDBDBD" BorderThickness="1" 
                                CornerRadius="8" Padding="10" Margin="0,0,0,15">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="💾 Сохраненные меню" FontSize="13" FontWeight="Bold" 
                                           Margin="0,0,0,10" Foreground="#2E7D32"/>

                                <DataGrid Grid.Row="1" Name="dgSavedMenus" AutoGenerateColumns="False" 
                                          IsReadOnly="True" SelectionChanged="dgSavedMenus_SelectionChanged"
                                          FontSize="12" Margin="0,5" Background="#FFFFFF" AlternatingRowBackground="#F1F8E9">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="📅 Дата" Width="100" Binding="{Binding DisplayDate}"/>
                                        <DataGridTextColumn Header="🍽️ Количество блюд" Width="130" Binding="{Binding DishesCount}"/>
                                        <DataGridTextColumn Header="📝 Примечания" Width="250" Binding="{Binding Notes}"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>

                        <!-- Кнопки действий -->
                        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,0">
                            <Button Name="btnDeleteSavedMenu" Content="🗑️ Удалить выбранное" Width="160" Height="32" 
                                    Margin="5" Click="btnDeleteSavedMenu_Click" 
                                    Background="#EF9A9A" Foreground="White" FontWeight="Bold" FontSize="12"/>
                            <Button Name="btnPrintMenu" Content="🖨️ Печать" Width="90" Height="32" 
                                    Margin="5" Click="btnPrintMenu_Click" 
                                    Background="#81C784" Foreground="White" FontWeight="Bold" FontSize="12"/>
                            <Button Name="btnExportToPDF" Content="📄 Экспорт в PDF" Width="120" Height="32" 
                                    Margin="5" Click="btnExportToPDF_Click" 
                                    Background="#66BB6A" Foreground="White" FontWeight="Bold" FontSize="12"/>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!-- Статусная строка -->
        <StatusBar Grid.Row="2" Margin="0,5,0,0" Background="#A5D6A7">
            <StatusBarItem>
                <TextBlock Name="txtStatus" Text="✅ Готов к работе. Нажмите 'Загрузить'" FontSize="11" Foreground="#1B5E20"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>