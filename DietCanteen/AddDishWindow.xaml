<Window x:Class="DietCanteen.AddDishWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавление нового блюда" Height="550" Width="650"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Название блюда -->
        <TextBlock Grid.Row="0" Text="Название блюда:" FontWeight="Bold" Margin="0,5"/>
        <TextBox Grid.Row="1" Name="txtDishName" Margin="0,0,0,10" Height="30"/>

        <!-- Цена -->
        <TextBlock Grid.Row="2" Text="Цена (руб):" FontWeight="Bold" Margin="0,5"/>
        <TextBox Grid.Row="3" Name="txtPrice" Margin="0,0,0,10" Height="30"/>

        <!-- В меню -->
        <CheckBox Grid.Row="4" Name="chkInMenu" Content="Включено в меню" Margin="0,5" FontWeight="Bold"/>

        <!-- Ингредиенты -->
        <TextBlock Grid.Row="5" Text="Ингредиенты:" FontWeight="Bold" Margin="0,10,0,5"/>

        <Grid Grid.Row="6">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Панель выбора продукта -->
            <Grid Grid.Row="0" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <ComboBox Grid.Column="0" Name="cmbProductName" Margin="5" 
                          DisplayMemberPath="Name" SelectedValuePath="Name"/>
                <TextBox Grid.Column="1" Name="txtQuantity" Margin="5" Text="100" ToolTip="Количество в граммах"/>
                <ComboBox Grid.Column="2" Name="cmbProcessing" Margin="5">
                    <ComboBoxItem>Варка</ComboBoxItem>
                    <ComboBoxItem>Жарка</ComboBoxItem>
                    <ComboBoxItem>Тушение</ComboBoxItem>
                    <ComboBoxItem>Запекание</ComboBoxItem>
                    <ComboBoxItem>Нарезка</ComboBoxItem>
                    <ComboBoxItem>Смешивание</ComboBoxItem>
                    <ComboBoxItem>Пассерование</ComboBoxItem>
                </ComboBox>
                <Button Grid.Column="3" Name="btnAddIngredient" Content="Добавить ингредиент" 
                        Width="140" Height="30" Margin="5" Click="btnAddIngredient_Click"/>
            </Grid>

            <!-- Таблица ингредиентов -->
            <DataGrid Grid.Row="1" Name="dgIngredients" AutoGenerateColumns="False" 
                      CanUserDeleteRows="True" Margin="0,5">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Продукт" Width="150" Binding="{Binding ProductName}"/>
                    <DataGridTextColumn Header="Количество (г)" Width="100" Binding="{Binding Quantity}"/>
                    <DataGridTextColumn Header="Обработка" Width="120" Binding="{Binding Processing}"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <!-- Кнопки действий -->
        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Name="btnSave" Content="Сохранить" Width="100" Height="35" 
                    Margin="5" Click="btnSave_Click" Background="LightGreen"/>
            <Button Name="btnCancel" Content="Отмена" Width="100" Height="35" 
                    Margin="5" Click="btnCancel_Click" Background="LightCoral"/>
        </StackPanel>
    </Grid>
</Window>